{
  "buildCommand": "cd web && bun install && bun run build",
  "outputDirectory": "web/dist",
  "functions": {
    "api/index.ts": {
      "runtime": "bun"
    }
  },
  "rewrites": [
    { "source": "/api/skill", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
